---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";

const settings = await getSiteSettings();
const menu = await getMenu("primary");
const navItems = menu?.items ?? [];

interface Props {
  title?: string;
  description?: string;
  entry?: any;
}

const { title, description, entry } = Astro.props;

const pageCtx = createPublicPageContext({
  Astro,
  kind: entry ? "content" : "custom",
  title: title || entry?.data?.title || settings?.data?.title,
  description: description || entry?.data?.meta_description || settings?.data?.tagline,
  content: entry ? { collection: "pages", id: entry.data.id, slug: entry.id } : undefined,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageCtx.title}</title>
    {pageCtx.description && <meta name="description" content={pageCtx.description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:wght@400;600;700&family=Ubuntu:wght@400;500&family=Benne&display=swap" rel="stylesheet" />
    <EmDashHead page={pageCtx} />
  </head>
  <body>
    <EmDashBodyStart page={pageCtx} />

    <slot name="header" />

    <main>
      <slot />
    </main>

    <slot name="footer" />

    <EmDashBodyEnd page={pageCtx} />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-primary: #023750;
    --color-accent:  #BECA5C;
    --color-body-text: #666666;
    --color-heading: #333333;
    --color-white:   #FFFFFF;
    --color-footer-bg: #1C1C1C;
    --font-heading:  "Josefin Sans", sans-serif;
    --font-body:     "Ubuntu", sans-serif;
    --font-serif:    "Benne", serif;
    --max-width:     1200px;
  }

  body {
    font-family: var(--font-body);
    color: var(--color-body-text);
    background: var(--color-white);
    line-height: 1.6;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-heading);
    color: var(--color-heading);
    text-transform: uppercase;
    font-weight: 700;
  }

  /* ── Buttons ──────────────────────────────────── */
  .btn {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 2rem;
    cursor: pointer;
    border: none;
    transition: background 0.2s, color 0.2s;
    border-radius: 0;
  }
  .btn-accent {
    background: var(--color-accent);
    color: #333333;
  }
  .btn-accent:hover {
    background: #a8b540;
  }
  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
  }
  .btn-outline:hover {
    background: var(--color-accent);
    color: #333333;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
