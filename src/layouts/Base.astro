---
import { getMenu, getSiteSettings } from "emdash";
import { EmDashHead, EmDashBodyStart, EmDashBodyEnd } from "emdash/ui";
import { createPublicPageContext } from "emdash/page";

const settings = await getSiteSettings();
const menu = await getMenu("primary");
const navItems = menu?.items ?? [];

interface Props {
  title?: string;
  description?: string;
  entry?: any;
  collection?: string;
}

const { title, description, entry, collection = "pages" } = Astro.props;

const pageCtx = createPublicPageContext({
  Astro,
  kind: entry ? "content" : "custom",
  title: title || entry?.data?.title || settings?.data?.title,
  description: description || entry?.data?.meta_description || settings?.data?.tagline,
  content: entry ? { collection, id: entry.data.id || entry.id, slug: entry.id } : undefined,
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageCtx.title}</title>
    {pageCtx.description && <meta name="description" content={pageCtx.description} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
    <EmDashHead page={pageCtx} />
  </head>
  <body>
    <EmDashBodyStart page={pageCtx} />

    <slot name="header" />

    <main>
      <slot />
    </main>

    <slot name="footer" />

    <EmDashBodyEnd page={pageCtx} />
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --color-primary: #1a2c38;
    --color-accent:  #C5A059;
    --color-lime:    #bed05c;
    --color-lime-dark: #a9ba4a;
    --color-body-text: #333333;
    --color-heading: #1a2c38;
    --color-white:   #FFFFFF;
    --color-footer-bg: #1C1C1C;
    --font-heading:  "Playfair Display", serif;
    --font-body:     "Montserrat", sans-serif;
    --font-serif:    "Playfair Display", serif;
    --max-width:     1440px;
  }

  body {
    font-family: var(--font-body);
    color: var(--color-body-text);
    background: var(--color-white);
    line-height: 1.6;
    font-size: 16px;
  }

  h1, h2, h3, h4 {
    font-family: var(--font-heading);
    color: var(--color-heading);
    text-transform: none;
    font-weight: 700;
  }

  /* ── Buttons ──────────────────────────────────── */
  .btn {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 1rem 2rem;
    cursor: pointer;
    border: none;
    transition: all 0.3s ease;
    border-radius: 21px;
  }
  .btn-accent {
    background: var(--color-accent);
    color: #002147;
  }
  .btn-accent:hover {
    background: #b08f4f;
    color: #002147;
    transform: translateY(-2px);
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  }
  .btn-outline {
    background: transparent;
    border: 2px solid var(--color-accent);
    color: var(--color-accent);
  }
  .btn-outline:hover {
    background: var(--color-accent);
    color: #fff;
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }
</style>
