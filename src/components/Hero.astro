---
import AwardBadges from './AwardBadges.astro';
---

<section class="hero">
  <div class="hero-overlay"></div>
  <div class="container hero-content">
    <div class="hero-text-wrap">
      <p class="hero-eyebrow">When your freedom is on the line, you need the <strong>BEST Criminal Defense.</strong></p>
      <a href="/contact" class="btn btn-accent hero-btn">FREE CONSULTATION</a>
    </div>
    
    <div class="hero-bottom">
      <p class="hero-subheading">GET AN AWARD-WINNING CRIMINAL DEFENSE</p>
      <h1 class="hero-title">Criminal Defense Attorney Springfield MO</h1>
      <AwardBadges />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background-image: url('/assets/Carver-law-hero-background.jpg');
    background-size: cover;
    background-position: center;
    min-height: 90vh;
    display: flex;
    align-items: center;
    color: #fff;
    padding: 6rem 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 55, 80, 0.4);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    text-align: right;
  }

  .hero-text-wrap {
    margin-bottom: 4rem;
  }

  .hero-eyebrow {
    font-size: 1.5rem;
    margin-bottom: 2rem;
    line-height: 1.4;
    max-width: 500px;
    margin-left: auto;
  }

  .hero-eyebrow strong {
    color: var(--color-accent);
  }

  .hero-btn {
    font-size: 1.1rem;
    padding: 1.2rem 2.5rem;
  }

  .hero-bottom {
    text-align: center;
    margin-top: 4rem;
  }

  .hero-subheading {
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    margin-bottom: 0.5rem;
  }

  .hero-title {
    font-size: 3.5rem;
    margin-bottom: 3rem;
    color: #fff;
  }

  @media (max-width: 768px) {
    .hero-title { font-size: 2.2rem; }
    .hero-eyebrow { font-size: 1.2rem; text-align: center; margin: 0 auto 2rem; }
    .hero-content { text-align: center; }
  }
</style>
