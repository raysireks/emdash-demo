---
import AwardBadges from './AwardBadges.astro';
---

<section class="hero">
  <div class="hero-main">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <div class="hero-text-wrap">
        <h1 class="hero-title">
          When your<br/>
          freedom is on the<br/>
          line, you need the<br/>
          <strong>BEST Criminal<br/>
          Defense.</strong>
        </h1>
        
        <div class="hero-actions">
          <a href="/contact" class="btn btn-lime hero-btn">+ FREE CONSULTATION</a>
        </div>
      </div>
    </div>
  </div>

  <div class="award-banner">
    <div class="award-banner-inner text-center">
      <p class="banner-tag">GET AN AWARD-WINNING CRIMINAL DEFENSE</p>
      <h2 class="banner-title">Criminal Defense Attorney Springfield MO</h2>
      <div class="hero-badges-wrap">
        <AwardBadges />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    color: #fff;
    background-image: url('/assets/Carver-law-hero-background.jpg');
    background-size: cover;
    background-position: center top;
  }

  .hero-main {
    position: relative;
    min-height: 95vh;
    display: flex;
    align-items: center;
    padding: 180px 0 80px; /* Offset for the fixed header */
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(0, 0, 0, 0.3), rgba(26, 44, 56, 0.5));
  }

  .hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: flex-end;
    width: 100%;
  }

  .hero-text-wrap {
    max-width: 700px;
    text-align: left;
  }

  .hero-title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.2rem);
    line-height: 1.1;
    margin-bottom: 3rem;
    color: #fff;
    font-weight: 500;
    text-transform: none;
    letter-spacing: -0.01em;
  }

  .hero-title strong {
    font-weight: 700;
  }

  .btn-lime {
    background: var(--color-lime);
    color: var(--color-primary);
  }

  .btn-lime:hover {
    background: var(--color-lime-dark);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(0,0,0,0.2);
  }

  .hero-btn {
    font-size: 1.1rem;
    padding: 1.25rem 3rem;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  /* Awards Banner Section */
  .award-banner {
    position: relative;
    padding: 5rem 0;
    background: linear-gradient(to bottom, 
      rgba(26, 44, 56, 0.8) 0%, 
      var(--color-primary) 100%
    );
    backdrop-filter: blur(4px);
    z-index: 10;
  }

  .award-banner-inner {
    padding: 0 4%;
    width: 100%;
    margin: 0 auto;
  }

  .text-center { text-align: center; }

  .banner-tag {
    font-family: var(--font-body);
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--color-lime);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .banner-title {
    font-family: var(--font-body);
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
    margin-bottom: 3rem;
    text-transform: none;
  }

  .hero-badges-wrap {
    max-width: 100%;
    width: 100%;
    margin: 0 auto;
  }

  .hero-badges-wrap :global(.award-badges) {
    justify-content: space-between;
    margin-top: 0;
    gap: 1rem;
  }

  .hero-badges-wrap :global(.award-badges img) {
    height: 90px;
    opacity: 0.95;
  }

  @media (max-width: 1024px) {
    .hero { background-attachment: scroll; }
    .hero-main { min-height: auto; padding: 6rem 0; }
    .hero-content { justify-content: center; }
    .hero-text-wrap { text-align: center; }
    .hero-title { font-size: 2.8rem; }
    .banner-tag { font-size: 1.4rem; }
  }
</style>
