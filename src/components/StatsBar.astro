---
---
<section class="stats section">
  <div class="container stats-grid">
    <div class="stats-text">
      <p class="eyebrow">VAST EXPERIENCE, UNMATCHED RESULTS</p>
      <h2>Over 45 Years of Excellence</h2>
      <div class="stats-items">
        <div class="stat-item">
          <span class="stat-number">45+</span>
          <span class="stat-label">YEARS EXPERIENCE</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">300+</span>
          <span class="stat-label">FEDERAL CASES</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">1000+</span>
          <span class="stat-label">SATISFIED CLIENTS</span>
        </div>
      </div>
      <a href="/contact" class="btn btn-accent">FREE CONSULTATION</a>
    </div>
    <div class="stats-image">
      <img src="/assets/Thomas-Carver-attorney-headshot.jpg" alt="Thomas Carver" />
    </div>
  </div>
</section>

<style>
  .stats { background: #fff; padding: 6rem 0; }
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
  }
  .eyebrow { color: var(--color-accent); font-weight: 700; letter-spacing: 0.15em; }
  .stats-text h2 { font-size: 2.5rem; margin-bottom: 2rem; }
  
  .stats-items {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .stat-item { display: flex; flex-direction: column; }
  .stat-number { font-size: 2.5rem; font-weight: 700; color: var(--color-primary); }
  .stat-label { font-size: 0.8rem; font-weight: 700; color: #999; letter-spacing: 0.1em; }

  .stats-image img {
    width: 100%;
    height: auto;
    box-shadow: 20px 20px 0 var(--color-accent);
  }

  @media (max-width: 768px) {
    .stats-grid { grid-template-columns: 1fr; }
    .stats-items { flex-direction: column; gap: 1rem; }
  }
</style>
