---
---
<section class="section-contact-v3" style="background: #1e3c5a; padding: 100px 0; color: #ffffff; position: relative; z-index: 1;">
  <div class="contact-wrap-v3" style="max-width: 1200px; margin: 0 auto; padding: 0 20px; text-align: center;">
    <h2 class="contact-title-v3" style="color: #bed05c; font-family: sans-serif; font-size: 2.5rem; font-weight: 800; letter-spacing: 0.05em; margin-bottom: 70px; text-transform: uppercase;">CONTACT US</h2>
    
    <form class="contact-form-v3" style="display: flex; flex-direction: column; gap: 40px; text-align: left;">
      <div class="form-row-v3" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px;">
        <div class="form-group-v3">
          <label style="display: block; font-family: sans-serif; font-size: 0.95rem; font-weight: 500; margin-bottom: 10px; color: #ffffff;">Name *</label>
          <input type="text" style="width: 100%; background: transparent; border: none; border-bottom: 1px solid #bed05c; border-radius: 0; padding: 8px 0; color: #ffffff; font-family: sans-serif; font-size: 1.1rem; outline: none;" required />
        </div>
        <div class="form-group-v3">
          <label style="display: block; font-family: sans-serif; font-size: 0.95rem; font-weight: 500; margin-bottom: 10px; color: #ffffff;">Email *</label>
          <input type="email" style="width: 100%; background: transparent; border: none; border-bottom: 1px solid #bed05c; border-radius: 0; padding: 8px 0; color: #ffffff; font-family: sans-serif; font-size: 1.1rem; outline: none;" required />
        </div>
      </div>

      <div class="form-group-v3">
        <label style="display: block; font-family: sans-serif; font-size: 0.95rem; font-weight: 500; margin-bottom: 10px; color: #ffffff;">Phone *</label>
        <input type="tel" style="width: 100%; background: transparent; border: none; border-bottom: 1px solid #bed05c; border-radius: 0; padding: 8px 0; color: #ffffff; font-family: sans-serif; font-size: 1.1rem; outline: none;" required />
      </div>

      <div class="form-group-v3">
        <label style="display: block; font-family: sans-serif; font-size: 0.95rem; font-weight: 500; margin-bottom: 10px; color: #ffffff;">What happened? *</label>
        <textarea rows="2" style="width: 100%; background: transparent; border: none; border-bottom: 1px solid #bed05c; border-radius: 0; padding: 8px 0; color: #ffffff; font-family: sans-serif; font-size: 1.1rem; outline: none; resize: none;" required></textarea>
      </div>

      <div class="form-submit-v3" style="text-align: center; margin-top: 30px;">
        <button type="submit" style="background-color: #bed05c; color: #1a2c38; border: none; padding: 12px 60px; border-radius: 25px; font-family: sans-serif; font-size: 1rem; font-weight: 800; cursor: pointer; text-transform: uppercase; transition: transform 0.2s ease;">SUBMIT</button>
      </div>
    </form>
  </div>
</section>

<style>
  @media (max-width: 768px) {
    .form-row-v3 {
      grid-template-columns: 1fr !important;
      gap: 30px !important;
    }
  }
  input:focus, textarea:focus {
    border-bottom-width: 2px !important;
  }
</style>
