---
import Base from "../layouts/Base.astro";
---

<Base title="Award-Winning Criminal Defense Attorney Springfield MO" description="Elite Criminal Defense Attorney Springfield MO. 3X Lawyer of the Year. 40+ Years Experience. Free Consultation.">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">GET AN AWARD-WINNING CRIMINAL DEFENSE</p>
      <h1>Criminal Defense Attorney<br />Springfield MO</h1>
      <p class="hero-tagline">When your freedom is on the line, you need the BEST Criminal Defense.</p>
      <a href="/contact" class="btn btn-accent btn-lg">FREE CONSULTATION</a>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="why-us">
    <div class="container">
      <div class="section-intro">
        <p class="eyebrow">WHEN YOU WANT THE BEST</p>
        <h2>Criminal Lawyer Springfield MO</h2>
      </div>
      <div class="feature-grid">
        <div class="feature-card">
          <div class="feature-icon">⚖️</div>
          <h3>Courtroom Focused</h3>
          <p>Our work is centered on trial practice. As trial lawyers, our attorneys' work is heavily weighted toward complex criminal matters where courtroom performance matters most.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🏆</div>
          <h3>Unrivaled Experience</h3>
          <p>Thomas Carver brings nearly 50 years of practice and has represented thousands of clients in Missouri state and federal courts, including over 300 federal cases.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⭐</div>
          <h3>Recognized Excellence</h3>
          <p>Five-time "Lawyer of the Year" designation by Best Lawyers in the area of criminal law in Springfield, Missouri, plus AV Preeminent® rating from Martindale-Hubbell.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats">
    <div class="container stats-inner">
      <div class="stats-content">
        <p class="eyebrow">VAST EXPERIENCE, UNMATCHED RESULTS</p>
        <div class="stats-grid">
          <div class="stat">
            <span class="stat-number">50+</span>
            <span class="stat-label">Years of Excellence</span>
          </div>
          <div class="stat">
            <span class="stat-number">1,000+</span>
            <span class="stat-label">Satisfied Clients</span>
          </div>
          <div class="stat">
            <span class="stat-number">300+</span>
            <span class="stat-label">Federal Cases</span>
          </div>
        </div>
        <a href="/contact" class="btn btn-accent btn-lg">FREE CONSULTATION</a>
      </div>
      <div class="stats-photo">
        <div class="photo-placeholder">Thomas Carver<br />Attorney at Law</div>
      </div>
    </div>
  </section>

  <!-- Practice Areas -->
  <section class="practice-areas">
    <div class="container">
      <h2 class="section-title">Criminal Defense Practice Areas</h2>
      <div class="practice-grid">
        {[
          { label: "Tax Crimes", href: "/practice-areas/tax-crimes" },
          { label: "Federal Criminal", href: "/practice-areas/federal-criminal" },
          { label: "White Collar Crime", href: "/practice-areas/white-collar-crime" },
          { label: "DWI", href: "/practice-areas/dwi" },
          { label: "Misdemeanors", href: "/practice-areas/misdemeanors" },
          { label: "Felonies", href: "/practice-areas/felonies" },
          { label: "Expungement", href: "/practice-areas/expungement" },
          { label: "Drug Conspiracy", href: "/practice-areas/drug-conspiracy" },
        ].map((area) => (
          <a href={area.href} class="practice-card">
            <span class="practice-icon">⚖</span>
            <h4>{area.label}</h4>
            <span class="learn-more">LEARN MORE →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Hire Us Band -->
  <section class="why-band">
    <div class="container">
      <p class="eyebrow">LET US FIGHT FOR YOU</p>
      <h2>Criminal Law Firm in Springfield MO</h2>
      <div class="why-grid">
        <div class="why-item">
          <h3>Vigorously Fight the Prosecution's Case</h3>
        </div>
        <div class="why-item">
          <h3>Defend Your Constitutional Rights</h3>
        </div>
        <div class="why-item">
          <h3>Secure the Most Optimal Outcome for You</h3>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Strip -->
  <section class="contact-strip">
    <div class="container">
      <h2>Contact Us</h2>
      <p>Call <a href="tel:4173501172">(417) 350-1172</a> or send us a message for your free consultation.</p>
      <a href="/contact" class="btn btn-accent btn-lg">GET IN TOUCH</a>
    </div>
  </section>

</Base>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Hero ──────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 560px;
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #023750 0%, #01232e 100%);
    overflow: hidden;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(2, 55, 80, 0.65);
  }
  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 5rem 1.5rem;
    text-align: center;
    color: #fff;
  }
  .hero-eyebrow {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.8rem;
    letter-spacing: 0.2em;
    color: #BECA5C;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }
  .hero h1 {
    font-family: "Josefin Sans", sans-serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 1.25rem;
    letter-spacing: 0.03em;
  }
  .hero-tagline {
    font-size: 1.1rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 2rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .btn-lg {
    padding: 0.85rem 2rem;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
  }

  /* ── Why Us ──────────────────────────────────── */
  .why-us {
    padding: 5rem 0;
    background: #fff;
  }
  .section-intro {
    text-align: center;
    margin-bottom: 3rem;
  }
  .eyebrow {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #BECA5C;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .section-intro h2, .section-title {
    font-family: "Josefin Sans", sans-serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #333;
    font-weight: 700;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }
  .feature-card {
    background: #f8f9fa;
    border-top: 3px solid #BECA5C;
    padding: 2rem;
    border-radius: 2px;
  }
  .feature-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
  }
  .feature-card h3 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #023750;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }
  .feature-card p {
    font-size: 0.93rem;
    line-height: 1.7;
    color: #666;
  }

  /* ── Stats ──────────────────────────────────── */
  .stats {
    padding: 5rem 0;
    background: #f4f6f2;
  }
  .stats-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .stats-content .eyebrow { margin-bottom: 1.5rem; display: block; }
  .stats-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 2.5rem;
  }
  .stat {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    border-left: 4px solid #BECA5C;
    padding-left: 1rem;
  }
  .stat-number {
    font-family: "Josefin Sans", sans-serif;
    font-size: 2rem;
    font-weight: 700;
    color: #023750;
  }
  .stat-label {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #555;
  }
  .stats-photo {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .photo-placeholder {
    width: 100%;
    max-width: 400px;
    aspect-ratio: 3/4;
    background: linear-gradient(135deg, #023750, #01232e);
    color: rgba(255,255,255,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    font-family: "Josefin Sans", sans-serif;
    font-size: 1rem;
    letter-spacing: 0.08em;
    border-top: 4px solid #BECA5C;
  }

  /* ── Practice Areas ──────────────────────────── */
  .practice-areas {
    padding: 5rem 0;
    background: #fff;
  }
  .section-title {
    text-align: center;
    margin-bottom: 3rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .practice-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .practice-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 2rem 1.25rem;
    background: #f8f9fa;
    border: 1px solid #e5e7eb;
    border-bottom: 3px solid #BECA5C;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    border-radius: 2px;
  }
  .practice-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(2,55,80,0.12);
  }
  .practice-icon {
    font-size: 2rem;
    margin-bottom: 0.75rem;
    display: block;
  }
  .practice-card h4 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #023750;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 1rem;
  }
  .learn-more {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: #023750;
    text-transform: uppercase;
    background: #BECA5C;
    padding: 0.4rem 0.9rem;
    display: inline-block;
  }

  /* ── Why Band ──────────────────────────────────── */
  .why-band {
    padding: 5rem 0;
    background: #023750;
    color: #fff;
    text-align: center;
  }
  .why-band .eyebrow { color: #BECA5C; }
  .why-band h2 {
    font-family: "Josefin Sans", sans-serif;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: #fff;
    font-weight: 700;
    margin-bottom: 3rem;
  }
  .why-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 2rem;
  }
  .why-item {
    padding: 1.5rem;
    border: 1px solid rgba(190,202,92,0.3);
    border-top: 3px solid #BECA5C;
  }
  .why-item h3 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
  }

  /* ── Contact Strip ─────────────────────────────── */
  .contact-strip {
    padding: 4rem 0;
    background: #023750;
    text-align: center;
    color: #fff;
    border-top: 3px solid #BECA5C;
  }
  .contact-strip h2 {
    font-family: "Josefin Sans", sans-serif;
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }
  .contact-strip p {
    margin-bottom: 1.75rem;
    color: rgba(255,255,255,0.8);
  }
  .contact-strip a[href^="tel"] {
    color: #BECA5C;
    text-decoration: none;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .stats-inner { grid-template-columns: 1fr; }
    .stats-photo { display: none; }
  }
</style>
