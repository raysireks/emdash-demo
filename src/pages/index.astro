---
import { getEmDashEntry } from "emdash";
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Hero from "../components/Hero.astro";
import FeatureCards from "../components/FeatureCards.astro";
import StatsBar from "../components/StatsBar.astro";
import PracticeAreasGrid from "../components/PracticeAreasGrid.astro";
import Services from "../components/Services.astro";
import WhyCarverBand from "../components/WhyCarverBand.astro";
import ContactFormStrip from "../components/ContactFormStrip.astro";

const entryResult = await getEmDashEntry("pages", "home");
const entry = entryResult?.entry;
const cacheHint = entryResult?.cacheHint;

if (entry) {
  Astro.locals.emdash = { ...Astro.locals.emdash, entry };
  Astro.cache?.set(cacheHint);
}
---

<Base entry={entry}>
  <Header slot="header" />
  
  <Hero entry={entry} />
  <FeatureCards entry={entry} />
  <StatsBar entry={entry} />
  <PracticeAreasGrid entry={entry} />
  <Services entry={entry} />
  <WhyCarverBand entry={entry} />
  <ContactFormStrip entry={entry} />

  <Footer slot="footer" />
</Base>
