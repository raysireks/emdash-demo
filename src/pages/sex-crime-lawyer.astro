---
import Base from "../layouts/Base.astro";
---

<Base title="SEX CRIME LAWYER | Carver & Associates" description="Final site content for SEX CRIME LAWYER at its original root path.">
  <section class="page-header">
    <div class="container text-center">
      <h1>SEX CRIME LAWYER</h1>
      <p class="subtitle">Criminal Defense Specialty</p>
    </div>
  </section>

  <section class="content-section">
    <div class="container">
      <div class="placeholder-content">
        <h2>Defending Your Rights: SEX CRIME LAWYER</h2>
        <p>This is a live page at the exact root level path: /sex-crime-lawyer/</p>
      </div>
    </div>
  </section>
</Base>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .text-center { text-align: center; }
  .page-header { background: #f8f9fa; padding: 4rem 0; border-bottom: 2px solid #BECA5C; }
  .page-header h1 { font-family: var(--font-heading); font-size: 2.5rem; color: var(--color-primary); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.5rem; }
  .subtitle { font-family: var(--font-heading); letter-spacing: 0.2em; color: #BECA5C; text-transform: uppercase; font-weight: 600; }
