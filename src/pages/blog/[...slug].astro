---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const { slug } = Astro.params;

// Fetch the entry from "posts" collection
const entryResult = await getEmDashEntry("posts", slug);
const entry = entryResult?.entry;
const cacheHint = entryResult?.cacheHint;

if (!entry || entry.status === "draft") {
  return new Response("Post not found", { status: 404 });
}

// EmDash boilerplate
Astro.locals.emdash = Astro.locals.emdash || {};
Astro.locals.emdash.entry = entry;
Astro.cache?.set(cacheHint);
---

<Base entry={entry} collection="posts">
  <Header slot="header" />

  <!-- Premium Interior Hero -->
  <section class="page-hero-v3" style="background: #1e3c5a; padding: 120px 0 80px; color: #ffffff; text-align: center; position: relative; z-index: 1;">
    <div class="container-v3" style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
      <h1 style="font-family: sans-serif; font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 20px;">
        {entry.data.title}
      </h1>
      <div style="width: 60px; height: 4px; background: #bed05c; margin: 0 auto 20px;"></div>
      <p style="font-family: sans-serif; font-size: 0.9rem; font-weight: 700; color: #bed05c; text-transform: uppercase; letter-spacing: 0.2em;">
        LEGAL BLOG & UPDATES
      </p>
    </div>
  </section>

  <!-- Content Section -->
  <section class="content-section-v3" style="padding: 100px 0; background: #ffffff;">
    <div class="container-v3" style="max-width: 800px; margin: 0 auto; padding: 0 20px;">
      <article class="cms-content-v3" style="font-family: sans-serif; line-height: 1.8; color: #333333; font-size: 1.1rem;">
        {entry.data.excerpt && (
          <div style="font-size: 1.2rem; font-weight: 600; color: #666; font-style: italic; margin-bottom: 40px; border-left: 4px solid #bed05c; padding-left: 20px;">
            {entry.data.excerpt}
          </div>
        )}
        <PortableText value={entry.data.content} />
      </article>
      
      <div style="margin-top: 80px; padding-top: 40px; border-top: 1px solid #eee; text-align: center;">
        <p style="font-size: 0.9rem; color: #666; margin-bottom: 20px;">Interested in learning more about your legal rights?</p>
        <a href="/blog" style="color: #1a2c38; font-weight: 700; text-decoration: none; border-bottom: 2px solid #bed05c;">Back to All Posts</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>

<style is:global>
  .cms-content-v3 h2 {
    font-family: sans-serif;
    font-weight: 800;
    font-size: 1.8rem;
    color: #1a2c38;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
  }
  .cms-content-v3 p {
    margin-bottom: 1.5rem;
  }
</style>
